{
	"name": "seanbehan-ca",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "npm run build && wrangler pages dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"deploy": "npm run build && wrangler pages deploy",
		"cf-typegen": "wrangler types && mv worker-configuration.d.ts src/"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260719.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.3.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.3.3",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"carbon-components": "^10.59.2",
		"carbon-components-svelte": "^0.110.1",
		"carbon-icons-svelte": "^13.13.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"fuse.js": "^7.5.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"mdsvex": "^0.12.8",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.1",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"wrangler": "^4.112.0"
	},
	"dependencies": {
		"typescript": "^6.0.3"
	},
	"allowScripts": {
		"carbon-components@10.59.2": true,
		"carbon-components-svelte@0.110.0": true,
		"esbuild@0.28.1": true,
		"sharp@0.34.5": true,
		"workerd@1.20260708.1": true
	}
}
